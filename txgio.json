{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://raw.githubusercontent.com/TNRIS/stac_extensions_txgio/refs/heads/main/txgio.json",
    "title": "TNRIS STAC schema",
    "description": "Metadata STAC Extension for STAC Items and STAC Collections pertaining to all TxGIO Collections. Meant to be used on collection.",
    "type": "object",
    "allOf": [
        {"$ref": "#/definitions/txgio"}
    ],
    "definitions": {
        "txgio": {
            "required": ["txgio:categories", "txgio:spatial_reference", "txgio:s_three_bucket_key", "txgio:public", "txgio:availability", "txgio:last_modified", "txgio:last_edited_by", "txgio:template"],
            "properties": {
                "txgio:collection_id": {
                    "title": "Collection ID",
                    "description": "Legacy collection id from api.",
                    "type": "string"
                },
                "txgio:publication_date": {
                    "title": "Publication Date",
                    "description": "Publication Date",
                    "type": "string",
                    "format": "date"
                },
                "txgio:categories": {
                    "$ref": "categories_enum.json"
                },
                "txgio:geometry": {
                    "title": "Geometry",
                    "$ref": "https://geojson.org/schema/GeoJSON.json"
                },
                "txgio:notes": {
                    "title": "Notes",
                    "type": "string"
                },
                "txgio:spatial_reference": {
                    "title": "Spatial Reference",
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "txgio:resolution": {
                    "title": "Resolution",
                    "type": "string"
                },
                "txgio:bands": {
                    "title": "Band Types",
                    "type": "array"
                },
                "txgio:citation": {
                    "title": "Resolution",
                    "type": "string"
                },
                "txgio:spatial_keywords": {
                    "title": "Spatial Keywords",
                    "description": "Spatial Keywords",
                    "type": "string"
                },
                "txgio:s_three_bucket_key": {
                    "title": "S3 Key",
                    "type": "string"
                },
                "txgio:public": {
                    "title": "Public/Publish",
                    "type": "boolean"
                },
                "txgio:availability": {
                    "title": "Availability",
                    "description": "Availability of this collection.",
                    "type": "boolean"
                },
                "txgio:banner_text": {
                    "title": "Banner Text",
                    "type": "string"
                },
                "txgio:last_modified": {
                    "title": "Last Modified",
                    "type": "string",
                    "format": "date"
                },
                "txgio:last_edited_by": {
                    "title": "Last Edited By",
                    "type": "string"
                },
                "txgio:template": {
                    "title": "Template",
                    "type": "string"
                }
            }
        }
    }
}