{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://raw.githubusercontent.com/TNRIS/stac_extensions_txgio/refs/heads/main/txgio.json",
    "title": "TNRIS STAC schema",
    "description": "Metadata STAC Extension for STAC Items and STAC Collections pertaining to all TxGIO Collections. Meant to be used on collection.",
    "type": "object",
    "allOf": [
        {"$ref": "#/definitions/txgio"}
    ],
    "definitions": {
        "txgio": {
            "required": ["txgio:collection_id", "txgio:categories"],
            "properties": {
                "txgio:collection_id": {
                    "title": "Collection ID",
                    "description": "The ID (uuid) of the collection.",
                    "type": "string"
                },
                "txgio:categories": {
                    "$ref": "categories_enum.json"
                },
                "txgio:acquisition_date": {
                    "title": "Acquisition Date",
                    "description": "Date this collection was acquired.",
                    "type": ["string", "null"]
                },

                "txgio:availability": {
                    "title": "Availability",
                    "description": "Availability of this collection.",
                    "type": ["string", "null"]
                },
                "txgio:counties": {
                    "$ref": "counties_enum.json"
                },
                "txgio:spatial_keywords": {
                    "title": "Spatial Keywords",
                    "description": "Spatial Keywords",
                    "type": ["string", "null"]
                },
                "txgio:data_types": {
                    "title": "Data Types",
                    "description": "Data types of the resources in the collection.",
                    "type": ["string", "null"]
                },
                "txgio:layman_types": {
                    "title": "Layman  Datatypes.",
                    "description": "A type acronym for the people."
                },
                "txgio:file_type": {
                    "title": "File Type",
                    "description": "The file type of this collection.",
                    "type": ["string", "null"]
                },
                "txgio:known_issues": {
                    "title": "Known Issues",
                    "description": "Known issues for this collection.",
                    "type": ["string", "null"]
                },
                "txgio:license_abbreviation": {
                    "title": "License Abbreviation",
                    "description": "A shorthand abbreviation of the license this imagery is distributed under..",
                    "type": ["string", "null"]
                },
                "txgio:license_url": {
                    "title": "License Url",
                    "description": "URL of the license.",
                    "type": ["string", "null"]
                },
                "txgio:public": {
                    "title": "Public",
                    "description": "Public?",
                    "type": "boolean"
                },
                "txgio:publication_date": {
                    "title": "Publication Date",
                    "description": "Publication Date",
                    "type": ["string", "null"]
                },
                "txgio:recommended_use": {
                    "title": "Recommended Use",
                    "description": "Recommended Use",
                    "type": ["string", "null"]
                }
            }
        }
    }
}
